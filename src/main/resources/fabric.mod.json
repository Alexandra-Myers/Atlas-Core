{
  "schemaVersion": 1,
  "id": "atlas-core",
  "version": "${version}",

  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "Alexandra"
  ],
  "contact": {},
  "license": "${mod_license}",
  "icon": "assets/atlas-core/icon.png",
  "accessWidener": "atlas-core.classtweaker",

  "environment": "*",
  "entrypoints": {
    "client": [
      "net.atlas.atlascore.fabric.client.AtlasCoreFabricClient"
    ],
    "main": [
      "net.atlas.atlascore.fabric.AtlasCoreFabric"
    ],
    "modmenu": [
      "net.atlas.atlascore.fabric.impl.ModMenuApiImpl"
    ]
  },
  "mixins": [
    "atlas-core.mixins.json"
  ],
  "depends": {
    "fabric-api": ">=${fabric_api_version}",
    "fabricloader": ">=${fabric_version}",
    "minecraft": "${minecraft}",
    "java": ">=${java}"
  }
}
